{
  "name": "qa-wolf-take-home",
  "version": "1.0.0",
  "description": "Playwright + TypeScript suite validating that the first 100 Hacker News /newest articles are sorted newest to oldest, at the UI and API layers",
  "author": "Jimmy Myers",
  "license": "ISC",
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "test": "playwright test --project=chromium --project=db",
    "test:ui": "playwright test --project=chromium tests/ui.spec.ts",
    "test:api": "playwright test --project=chromium tests/api.spec.ts",
    "test:list": "playwright test --project=chromium tests/list-pages.spec.ts",
    "test:db": "playwright test --project=db",
    "test:a11y": "playwright test --project=chromium tests/a11y.spec.ts",
    "test:unit": "vitest run",
    "test:all": "npm run test:unit && npm test",
    "demo:fail": "playwright test --project=demo-fail",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
